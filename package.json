{
  "name": "marklog-local",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first planning document archive server shared as source and run from a clone.",
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "engines": {
    "node": ">=25",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "dev:lan": "HOST=0.0.0.0 tsx src/server/index.ts",
    "clean": "node scripts/clean.mjs",
    "build": "pnpm clean && tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "start:lan": "HOST=0.0.0.0 NODE_ENV=production node dist/server/index.js",
    "marklog": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "bin": {
    "marklog": "dist/cli.js"
  },
  "dependencies": {
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "diff": "^8.0.2",
    "fastify": "^5.6.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "simple-git": "^3.30.0",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
